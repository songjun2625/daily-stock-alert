# 데일리 픽 환경변수 — 이 파일을 .env 로 복사 후 채워주세요.
# .env 는 .gitignore 에 등록되어 GitHub 에 절대 올라가지 않습니다.

# ---- 솔라피 (SOLAPI) ----------------------------------------------------
# https://solapi.com 가입 후 [개발 → API Key] 메뉴에서 발급
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=01012345678            # 본인 휴대폰 — 사전 발신번호 등록 필수 (24h)

# ---- 카카오 알림톡 ------------------------------------------------------
# 카카오톡 채널 → 솔라피에 채널 연동 후 발급되는 비즈니스 채널 ID
ALIMTALK_PFID=

# 검수 통과 후 카카오에서 부여하는 템플릿 ID (등록 직후 빈 값으로 두기)
ALIMTALK_TEMPLATE_ID_KR=
ALIMTALK_TEMPLATE_ID_US=
ALIMTALK_TEMPLATE_ID_PAYMENT_D1=
ALIMTALK_TEMPLATE_ID_WELCOME=
ALIMTALK_TEMPLATE_ID_TRIAL_END=

# ---- 본인 테스트 수신 번호 ----------------------------------------------
TEST_RECIPIENT=01012345678

# ---- 자동 발송 모드 (운영 시 true, 안정화 전 비워두기) -------------------
AUTO_SEND=

# ---- Supabase (옵션 — 운영 단계에서 필요) -------------------------------
SUPABASE_URL=
SUPABASE_KEY=

# ---- 토스페이먼츠 (옵션 — 결제 단계에서 필요) ----------------------------
PAYMENT_REDIRECT_BASE=https://api.tosspayments.com/v1/billing/authorizations
PAYMENT_SUCCESS_URL=https://dailypick.kr/payments/success
PAYMENT_FAIL_URL=https://dailypick.kr/payments/fail
